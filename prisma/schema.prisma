generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  emailVerified        DateTime?
  name                 String?
  password             String?
  image                String?
  userType             String    @default("normal")  // "normal" | "agency"
  onboardingCompleted  Boolean   @default(false)
  onboardingStep       Int       @default(0)
  
  // All users have a default workspace created during signup
  defaultWorkspaceId   String?
  
  // Workspace membership
  workspaces           WorkspaceMember[]
  
  // Authentication
  accounts             Account[]
  sessions             Session[]
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id               String   @id @default(cuid())
  name             String
  description      String?
  
  // Workspace members
  members          WorkspaceMember[]
  
  // Workspace data (one-to-one relationship)
  workspaceData    WorkspaceData?
  
  // Scrape runs
  scrapeRuns       ScrapeRun[]

  // AEO Audits
  aeoAudits        AeoAudit[]

  // Tracked prompts
  trackedPrompts   TrackedPrompt[]

  // Brand fields (populated during onboarding)
  brandName        String?
  brandAliases     String?
  website          String?
  twitterHandle    String?
  linkedinHandle   String?
  country          String?
  industry         String?
  brandDescription String?
  targetKeywords   String?

  // Starter prompts saved during onboarding (JSON array stored as string)
  starterPrompts   String?

  // Competitors
  competitors      Competitor[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Competitor {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  url         String?
  type        String    @default("direct")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("member")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, workspaceId])
}

model WorkspaceData {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  data        Json
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrackedPrompt {
  id          String     @id @default(cuid())
  workspaceId String
  text        String
  label       String?
  isActive    Boolean    @default(true)
  schedule    String     @default("none")  // none | hourly | daily | weekly | monthly (Phase 3)
  lastRunAt   DateTime?
  deletedAt   DateTime?                    // soft delete — null means active

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scrapeRuns  ScrapeRun[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workspaceId])
}

model ScrapeRun {
  id                 String   @id @default(cuid())
  workspaceId        String
  promptId           String?                // FK to TrackedPrompt — null for legacy/ad-hoc runs
  provider           String                 // chatgpt | perplexity | copilot | gemini | google_ai | grok
  prompt             String                 // snapshot of prompt text at run time
  answer             String
  sources            String   @default("[]")  // JSON array of URLs
  visibilityScore    Int      @default(0)
  sentiment          String   @default("not-mentioned") // positive | neutral | negative | not-mentioned
  brandMentions      String   @default("[]")  // JSON array of brand terms found
  competitorMentions String   @default("[]")  // JSON array of competitor terms found

  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  trackedPrompt      TrackedPrompt? @relation(fields: [promptId], references: [id], onDelete: SetNull)

  createdAt          DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([promptId, createdAt])
}

model AeoAudit {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  score       Int
  report      Json     // Stores the full AuditReport JSON
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
}